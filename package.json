{
  "name": "metronome",
  "version": "1.0.0",
  "description": "A web-based metronome inspired by Metronome Beats",
  "source": "src/index.html",
  "scripts": {
    "dev": "parcel serve src/index.html --open",
    "build": "rm -rf dist && parcel build src/index.html",
    "generate-audio": "bun scripts/generate-clicks.js",
    "predeploy": "bun run build",
    "deploy": "gh-pages -d dist"
  },
  "devDependencies": {
    "parcel": "^2.16.4"
  },
  "dependencies": {
    "gh-pages": "^6.3.0"
  }
}
